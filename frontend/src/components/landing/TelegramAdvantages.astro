---
import EyebrowLabel from "../shared/EyebrowLabel.astro";

const points = [
  { key: "telegram.point1", text: "Never miss a price drop" },
  { key: "telegram.point2", text: "Find out instantly when an item is back in stock" },
  { key: "telegram.point3", text: "Track several products at once" },
  { key: "telegram.point4", text: "Save time on manually checking stores" },
  { key: "telegram.point5", text: "Decide when to buy at the right moment" },
];
---

<section class="relative overflow-hidden bg-white py-20 px-6 lg:py-32">
  <div class="container mx-auto px-6">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div class="max-w-xl">
        <EyebrowLabel i18nKey="telegram.eyebrow" text="Why Telegram"  class="ml-0"/>
        <h2
          data-i18n="telegram.title"
          class="text-3xl font-bold text-slate-900 md:text-5xl"
        >
          Why a Telegram bot beats checking manually
        </h2>
        <p data-i18n="telegram.subtitle" class="mt-5 text-lg leading-8 text-slate-500">
          No app to install, no tabs to keep open — alerts arrive where you already read messages.
        </p>
      </div>

      <ul class="grid gap-4 sm:grid-cols-2">
        {
          points.map((p) => (
            <li class="flex items-start gap-3 rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
              <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gradient-to-r from-[#6A5AF9] to-[#049fff] text-white">
                <svg viewBox="0 0 16 16" class="h-3.5 w-3.5 fill-current">
                  <path d="M6.4 11.2 2.8 7.6l1.13-1.13L6.4 8.93l5.67-5.67L13.2 4.4z" />
                </svg>
              </span>
              <span data-i18n={p.key} class="font-medium text-slate-700">
                {p.text}
              </span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
