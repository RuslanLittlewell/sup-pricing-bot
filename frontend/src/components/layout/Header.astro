---

---

<header
  class="fixed left-0 right-0 top-0 z-50 border-b border-white/40 bg-white/55 shadow-sm shadow-slate-900/5 backdrop-blur-xl backdrop-saturate-150 transition-all duration-300 supports-[backdrop-filter]:bg-white/35"
>
  <nav class="container mx-auto px-6 py-4">
    <div class="flex justify-between items-center">
      <a class="group flex items-center" href="/" aria-label="SurPrice Bot"
        ><img
          src="/SPBLogo.svg"
          alt="SurPrice Bot"
          width="246"
          height="64"
          class="h-12 w-auto transition-transform duration-300 group-hover:scale-[1.03]"
        /> <span class="ml-5 text-2xl font-bold">Sur<span class="bg-gradient-to-r from-[#049fff] to-[#16C8BD] bg-clip-text text-transparent">Price</span> <span class="text-[#16C8BD]">Bot</span></span></a
      ><div class="hidden md:flex items-center gap-6">
        <a
          data-i18n="nav.features"
          class="text-slate-600 hover:text-[#049fff] transition-colors font-medium"
          href="/#features">Features</a
        ><a
          data-i18n="nav.pricing"
          class="text-slate-600 hover:text-[#049fff] transition-colors font-medium"
          href="/pricing">Pricing</a
        ><a
          data-i18n="nav.about"
          class="text-slate-600 hover:text-[#049fff] transition-colors font-medium"
          href="/about">About</a
        ><div class="flex items-center rounded-full border border-slate-200 bg-white/80 p-1 shadow-sm">
          <button
            type="button"
            data-lang-switch="ru"
            class="rounded-full px-3 py-1.5 text-xs font-bold text-slate-500 transition-colors"
            >RU</button
          ><button
            type="button"
            data-lang-switch="pl"
            class="rounded-full px-3 py-1.5 text-xs font-bold text-slate-500 transition-colors"
            >PL</button
          ><button
            type="button"
            data-lang-switch="en"
            class="rounded-full px-3 py-1.5 text-xs font-bold text-slate-500 transition-colors"
            >EN</button
          >
        </div
        ><a
          href="#"
          class="btn-primary bg-gradient-to-r from-[#6A5AF9] to-[#049fff] hover:opacity-90 text-white font-bold py-2.5 px-6 rounded-full transition-all duration-300 shadow-lg hover:shadow-xl hover:scale-105 animate-pulse-glow"
          ><span data-i18n="nav.cta">Start Now</span></a>
      </div><button
        class="md:hidden p-2 text-slate-600 hover:text-[#6A5AF9] transition-colors"
        aria-label="Toggle menu"
        ><svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path></svg
        ></button>
    </div><div
      class="md:hidden overflow-hidden transition-all duration-300 max-h-0 opacity-0"
    >
      <div class="flex flex-col gap-4 py-4 border-t border-slate-200">
        <a
          data-i18n="nav.features"
          class="text-slate-600 hover:text-[#6A5AF9] transition-colors font-medium py-2"
          href="/#features">Features</a
        ><a
          data-i18n="nav.pricing"
          class="text-slate-600 hover:text-[#6A5AF9] transition-colors font-medium py-2"
          href="/pricing">Pricing</a
        ><a
          data-i18n="nav.about"
          class="text-slate-600 hover:text-[#6A5AF9] transition-colors font-medium py-2"
          href="/about">About</a
        ><div class="flex w-fit items-center rounded-full border border-slate-200 bg-white/80 p-1 shadow-sm">
          <button
            type="button"
            data-lang-switch="ru"
            class="rounded-full px-3 py-1.5 text-xs font-bold text-slate-500 transition-colors"
            >RU</button
          ><button
            type="button"
            data-lang-switch="pl"
            class="rounded-full px-3 py-1.5 text-xs font-bold text-slate-500 transition-colors"
            >PL</button
          ><button
            type="button"
            data-lang-switch="en"
            class="rounded-full px-3 py-1.5 text-xs font-bold text-slate-500 transition-colors"
            >EN</button
          >
        </div
        ><a
          href="#"
          class="btn-primary bg-gradient-to-r from-[#6A5AF9] to-[#049fff] text-white font-bold py-3 px-6 rounded-full text-center shadow-lg"
          ><span data-i18n="nav.cta">Start Now</span></a>
      </div>
    </div>
  </nav>
</header>
