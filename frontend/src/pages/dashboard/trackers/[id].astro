---
import Layout from "../../../layouts/Layout.astro";
export async function getStaticPaths() { return []; }
const { id } = Astro.params;
---

<Layout title="Трекер — Price Tracker">
  <div class="container" style="margin-top:40px" id="app">
    <a href="/dashboard" style="color:#666;font-size:14px">← Назад</a>
    <h1 id="title" style="margin-top:16px"></h1>
    <p id="url" style="color:#666;word-break:break-all"></p>

    <div class="card" style="margin-top:16px">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
        <div id="info-left"></div>
        <div id="info-right"></div>
      </div>
      <button id="recheck-btn" class="btn" style="background:#eee;margin-top:16px">Проверить сейчас</button>
    </div>

    <h2 style="margin-top:24px">История цен</h2>
    <div id="price-history" class="card"><p style="color:#666">Нет данных</p></div>

    <h2 style="margin-top:24px">История наличия</h2>
    <div id="stock-history" class="card"><p style="color:#666">Нет данных</p></div>
  </div>
</Layout>

<script>
  const API = "";
  const id = window.location.pathname.split("/").pop();

  const labels: Record<string,string> = {
    in_stock: "В наличии", out_of_stock: "Нет в наличии", unknown: "Неизвестно",
  };

  async function load() {
    try {
      const me = await fetch(API + "/api/me", { credentials: "include" });
      if (!me.ok) { window.location.href = "/login"; return; }

      const [tracker, history] = await Promise.all([
        fetch(API + "/api/trackers/" + id, { credentials: "include" }).then(r => r.json()),
        fetch(API + "/api/trackers/" + id + "/history", { credentials: "include" }).then(r => r.json()),
      ]);
      render(tracker, history);
    } catch { window.location.href = "/login"; }
  }

  function render(t: any, h: any) {
    document.getElementById("title")!.textContent = t.title || t.domain;
    document.getElementById("url")!.textContent = t.url;

    document.getElementById("info-left")!.innerHTML = `
      <p><strong>Текущая цена:</strong> ${t.current_price ? t.current_price + " " + t.currency : "—"}</p>
      <p><strong>Начальная цена:</strong> ${t.initial_price} ${t.currency}</p>
      <p><strong>Наличие:</strong> ${labels[t.current_stock_status] || t.current_stock_status}</p>
    `;
    document.getElementById("info-right")!.innerHTML = `
      <p><strong>Статус:</strong> ${t.status}</p>
      <p><strong>Последняя проверка:</strong> ${t.last_checked_at ? new Date(t.last_checked_at).toLocaleString("ru-RU") : "—"}</p>
      ${t.last_error ? `<p style="color:red"><strong>Ошибка:</strong> ${t.last_error}</p>` : ""}
    `;

    document.getElementById("recheck-btn")!.onclick = async () => {
      await fetch(API + "/api/trackers/" + id + "/recheck", { method: "POST", credentials: "include" });
      alert("Трекер отправлен на проверку");
    };

    const prices = h.prices || [];
    document.getElementById("price-history")!.innerHTML = prices.length
      ? prices.map((p: any) => `<div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #eee">
          <span>${p.price ? p.price + " " + p.currency : "—"}</span>
          <span style="color:#666">${new Date(p.checked_at).toLocaleString("ru-RU")}</span>
        </div>`).join("")
      : '<p style="color:#666">Нет данных</p>';

    const stocks = h.stocks || [];
    document.getElementById("stock-history")!.innerHTML = stocks.length
      ? stocks.map((s: any) => `<div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #eee">
          <span>${labels[s.stock_status] || s.stock_status}</span>
          <span style="color:#666">${new Date(s.checked_at).toLocaleString("ru-RU")}</span>
        </div>`).join("")
      : '<p style="color:#666">Нет данных</p>';
  }

  load();
</script>
