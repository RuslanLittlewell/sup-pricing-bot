---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Telegram Price Tracker Bot — SurPrice Bot",
  description = "Track product prices, discounts and availability across online stores. Get Telegram alerts when prices drop or products come back in stock.",
