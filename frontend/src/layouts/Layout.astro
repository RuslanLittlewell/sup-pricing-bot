    <title data-i18n="meta.title">{title}</title>
    <meta name="description" content={description} data-i18n-content="meta.description" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
