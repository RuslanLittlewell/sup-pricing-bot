---
export interface Props {
  title?: string;
  description?: string;
}

const { title = "Price Tracker", description = "Отслеживание изменения цен и наличия товаров с уведомлениями в Telegram" } = Astro.props;

import Header from "@/components/layout/Header.astro";
import "../styles/globals.css";
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <Header />
    <main class="min-h-screen">
      <slot />
    </main>
    <script is:inline>
      const translations = {
        en: {
          "nav.features": "Features",
          "nav.pricing": "Pricing",
          "nav.about": "About",
          "nav.cta": "Start Now",
          "hero.title": "Never Miss a Product Price Drop",
          "hero.subtitle":
            "SurPrice is your Telegram bot for tracking product prices without the need to check stores manually.",
          "hero.cta": "Try Now",
          "home.title": "Price Tracker",
          "home.subtitle":
            "Track product prices and availability across stores. Get instant Telegram alerts when changes happen.",
          "home.login": "Login with Telegram",
          "info.eyebrow": "Price tracking via Telegram",
          "info.title": "Track product prices across online stores automatically",
          "info.description":
            "SurPrice monitors product pages, detects price and availability changes, and sends Telegram alerts when it is time to buy.",
          "info.card1.title": "Price drop alerts",
          "info.card1.text":
            "Add a product URL once and receive a Telegram notification when the price changes.",
          "info.card2.title": "Availability monitoring",
          "info.card2.text":
            "Track whether products are in stock, out of stock, or available again.",
          "info.card3.title": "Flexible scan intervals",
          "info.card3.text":
            "Choose how often each tracker checks the page: every hour, daily, or anything in between.",
        },
        ru: {
          "nav.features": "Возможности",
          "nav.pricing": "Цены",
          "nav.about": "О сервисе",
          "nav.cta": "Начать",
          "hero.title": "Не пропускайте снижение цены товара",
          "hero.subtitle":
            "SurPrice отслеживает цены товаров на сайтах и отправляет уведомления в Telegram, когда цена меняется.",
          "hero.cta": "Попробовать",
          "home.title": "Трекер цен",
          "home.subtitle":
            "Отслеживайте цены и наличие товаров в магазинах. Получайте мгновенные уведомления об изменениях в Telegram.",
          "home.login": "Войти через Telegram",
          "info.eyebrow": "Отслеживание цен в Telegram",
          "info.title": "Автоматически мониторьте цены товаров в интернет-магазинах",
          "info.description":
            "SurPrice проверяет страницы товаров, находит изменения цены и наличия и отправляет уведомления в Telegram, когда пора покупать.",
          "info.card1.title": "Уведомления о снижении цены",
          "info.card1.text":
            "Добавьте ссылку на товар один раз и получите сообщение в Telegram, когда цена изменится.",
          "info.card2.title": "Контроль наличия",
          "info.card2.text":
            "Следите, есть ли товар в наличии, закончился ли он или снова появился в продаже.",
          "info.card3.title": "Гибкая частота проверок",
          "info.card3.text":
            "Настраивайте, как часто проверять каждый товар: каждый час, раз в день или с другим интервалом.",
        },
        pl: {
          "nav.features": "Funkcje",
          "nav.pricing": "Cennik",
          "nav.about": "O projekcie",
          "nav.cta": "Zacznij",
          "hero.title": "Nie przegap obniżki ceny produktu",
          "hero.subtitle":
            "SurPrice monitoruje ceny produktów na stronach sklepów i wysyła powiadomienia w Telegramie, gdy cena się zmieni.",
          "hero.cta": "Wypróbuj",
          "home.title": "Monitoring cen",
          "home.subtitle":
            "Śledź ceny i dostępność produktów w sklepach. Otrzymuj natychmiastowe powiadomienia o zmianach w Telegramie.",
          "home.login": "Zaloguj przez Telegram",
          "info.eyebrow": "Monitoring cen w Telegramie",
          "info.title": "Automatycznie śledź ceny produktów w sklepach internetowych",
          "info.description":
            "SurPrice monitoruje strony produktów, wykrywa zmiany ceny i dostępności oraz wysyła powiadomienia w Telegramie, gdy warto kupić.",
          "info.card1.title": "Alerty o spadku ceny",
          "info.card1.text":
            "Dodaj link do produktu raz i otrzymaj powiadomienie w Telegramie, gdy cena się zmieni.",
          "info.card2.title": "Monitoring dostępności",
          "info.card2.text":
            "Sprawdzaj, czy produkt jest dostępny, wyprzedany albo ponownie wrócił do sprzedaży.",
          "info.card3.title": "Elastyczne interwały skanowania",
          "info.card3.text":
            "Ustaw, jak często sprawdzać każdy produkt: co godzinę, raz dziennie albo w innym rytmie.",
        },
      };

      const supportedLanguages = ["en", "ru", "pl"];
      const getInitialLanguage = () => {
        const urlLanguage = new URLSearchParams(window.location.search).get("lang");
        const storedLanguage = window.localStorage.getItem("surprice-language");
        const browserLanguage = navigator.language?.slice(0, 2);
        return [urlLanguage, storedLanguage, browserLanguage, "en"].find((lang) =>
          supportedLanguages.includes(lang)
        );
      };

      const setLanguage = (language) => {
        const dictionary = translations[language] || translations.en;
        document.documentElement.lang = language;
        window.localStorage.setItem("surprice-language", language);

        document.querySelectorAll("[data-i18n]").forEach((node) => {
          const key = node.getAttribute("data-i18n");
          if (dictionary[key]) {
            node.textContent = dictionary[key];
          }
        });

        document.querySelectorAll("[data-lang-switch]").forEach((button) => {
          const isActive = button.getAttribute("data-lang-switch") === language;
          button.classList.toggle("bg-gradient-to-r", isActive);
          button.classList.toggle("from-[#6A5AF9]", isActive);
          button.classList.toggle("to-[#049fff]", isActive);
          button.classList.toggle("shadow-sm", isActive);
          button.classList.toggle("text-white", isActive);
          button.classList.toggle("text-slate-500", !isActive);
        });
      };

      window.addEventListener("DOMContentLoaded", () => {
        setLanguage(getInitialLanguage());
        document.querySelectorAll("[data-lang-switch]").forEach((button) => {
          button.addEventListener("click", () => {
            setLanguage(button.getAttribute("data-lang-switch"));
          });
        });
      });
    </script>
  </body>
</html>
