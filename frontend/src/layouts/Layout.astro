---
export interface Props {
  title?: string;
  description?: string;
}

const { title = "Price Tracker", description = "Отслеживание изменения цен и наличия товаров с уведомлениями в Telegram" } = Astro.props;

import "../styles/globals.css";
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>
