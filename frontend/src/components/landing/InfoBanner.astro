---
import EyebrowLabel from "../shared/EyebrowLabel.astro";
import FeatureCard from "../shared/FeatureCard.astro";
import LightRays from "../shared/LightRays.astro";

const cards = [
  {
    titleKey: "info.card1.title",
    title: "Price drop alerts",
    textKey: "info.card1.text",
    text: "Add a product URL once and receive a Telegram notification when the price changes.",
  },
  {
    titleKey: "info.card2.title",
    title: "Availability monitoring",
    textKey: "info.card2.text",
    text: "Track whether products are in stock, out of stock, or available again.",
  },
  {
    titleKey: "info.card3.title",
    title: "Flexible scan intervals",
    textKey: "info.card3.text",
    text: "Choose how often each tracker checks the page: every hour, daily, or anything in between.",
  },
];
---

<section
  id="features"
  class="relative overflow-hidden bg-gradient-to-r from-[#6A5AF9] to-[#049fff] py-20 lg:py-32"
>
  <div class="absolute inset-0 bg-black/10"></div>

  <LightRays
    raysOrigin="left"
    raysColor="#ffffff"
    raysSpeed={0.8}
    lightSpread={0.8}
    rayLength={2.2}
    class="z-[1] opacity-60 mix-blend-screen"
  />

  <div
    class="pointer-events-none absolute -left-24 top-8 h-64 w-64 rounded-full bg-white/15 blur-3xl"
  >
  </div>
  <div
    class="pointer-events-none absolute -right-20 bottom-0 h-72 w-72 rounded-full bg-[#16C8BD]/25 blur-3xl"
  >
  </div>

  <div class="container relative z-10 mx-auto px-6">
    <div class="mx-auto max-w-4xl text-center">
      <EyebrowLabel i18nKey="info.eyebrow" text="Price tracking via Telegram" variant="dark" class="ml-auto" />
      <h2
        data-i18n="info.title"
        class="mb-4 text-3xl font-bold text-white md:text-5xl"
      >
        Track product prices across online stores automatically
      </h2>

      <p
        data-i18n="info.description"
        class="mx-auto mb-10 max-w-3xl text-lg leading-8 text-white/90"
      >
        SurPrice Bot monitors product pages, detects price and availability changes,
        and sends Telegram alerts when it is time to buy.
      </p>

      <div class="grid gap-4 text-left md:grid-cols-3">
        {cards.map((card) => <FeatureCard {...card} />)}
      </div>
    </div>
  </div>
</section>
