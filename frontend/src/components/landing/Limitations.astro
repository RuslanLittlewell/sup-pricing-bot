<section class="relative bg-slate-50 py-16 px-6">
  <div class="container mx-auto max-w-3xl px-6">
    <div class="flex gap-4 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8">
      <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-amber-100 text-amber-600">
